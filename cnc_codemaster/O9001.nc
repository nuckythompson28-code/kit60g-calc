%
O9001(MAIN LOGIC - PROTECTED);
;
(CALCULATE TOTAL LENGTH);
(#140 IS INTERNAL CALC VAR);
(#129 IS SAFE RESIDUAL);
#140=#101+#102-#129 (TOTAL LEN);
;
(FEED RATES INHERITED FROM O0852);
;
N90 (FEED SET COMPLETE);
;
(OPTIMIZATION PARAMS);
#505 = #113 + #114 (TOTAL UNIT LEN);
(#530 IS SAFETY LEN FROM O0852);
(#103 IS CHUCK LEN);
#602 = FIX[[#103 - #530] / #505];
#103 = [#602 * #505] + #530;
;
N999 (FINAL CALCULATION);
#500 = #103 - #530 (EFF LEN);
#517 = FIX[#500 / #505] (NUM PCS);
#518 = #517 * #505 (TOT MACH LEN);
;
;
(ALARM CHECKS);
N900;
(1. EXISTING CHECKS);
IF [#140 GT 580] GOTO 901;
IF [#140 LE #103] GOTO 907 (LEN SHORT);
IF [#109 LT #111] GOTO 902 (OD ERR);
IF [#110 GT #112] GOTO 903 (ID ERR);
IF [#125 GE 0.14] GOTO 904;
;
(2. MAT UNIT CHECK);
IF [[#102 NE 0] AND [#102 NE 100] AND [#102 NE 200] AND [#102 NE 300] AND [#102 NE 400] AND [#102 NE 500]] GOTO 905;
IF [#101 GT 99] GOTO 906;
;
(3. PARAMETER LIMITS);
IF [#104 GT 40] GOTO 910;
IF [#129 GT 30] GOTO 911;
IF [#123 LT 0] OR [#123 GT 3] GOTO 912;
IF [[#106 NE 3] AND [#106 NE 4]] GOTO 913;
;
(4. SAFETY CHECKS);
(CHECK 2: OD VS ID);
IF [#109 LE #110] GOTO 3203 (OD<=ID);
IF [#111 LE #112] GOTO 3204 (FIN OD<=ID);
;
(CHECK 3: INVALID VALS);
IF [#109 LE 0] GOTO 3205 (OD INVALID);
IF [#120 LE 0] GOTO 3206 (T01 RPM ERR);
IF [#121 LE 0] GOTO 3207 (T02 RPM ERR);
;
(CHECK 4: TIP WIDTH);
IF [#114 GE #113] GOTO 3208 (TIP > FIN LEN);
;
GOTO 9999 (ALL CHECKS OK);
;
;
(ALARM MESSAGES);
N901 #3000 = 1 (ERR: LEN > 580);
N902 #3000 = 2 (ERR: OD < WORK OD);
N903 #3000 = 3 (ERR: ID > WORK ID);
N904 #3000 = 4 (ALM: T01 FEED > 0.14);
N905 #3000 = 5 (ERR: CHECK #102);
N906 #3000 = 6 (ERR: CHECK #101);
N907 #3000 = 7 (ERR: LEN < REQ LEN);
N910 #3000 = 10 (ERR: INIT CUT > 40);
N911 #3000 = 11 (ERR: RES > 70);
N912 #3000 = 12 (ERR: BAD MAT TYPE);
N913 #3000 = 13 (ERR: #106 NOT 3/4);
;
(NEW LOGIC ALARMS 32xx);
N3203 #3000=203 (ERR: OD <= ID);
N3204 #3000=204 (ERR: FIN OD <= ID);
N3205 #3000=205 (ERR: BAD DIM);
N3206 #3000=206 (ERR: T01 RPM);
N3207 #3000=207 (ERR: T02 RPM);
N3208 #3000=208 (WARN: TIP > LEN);
;
N9999 (START PROCESS);
;
(SIZE2);
;
M[#131] (VAR CLAMP OPEN);
;
M98 P9002;
;
N22(CLOSING);
M05;
G53 G00 X[-310.] Z0.;
M99;
%
